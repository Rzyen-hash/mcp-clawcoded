# ⚠️  IMPORTANT: Copy this file to .env and fill in your actual values
# NEVER commit .env to git!

# NOTE: This MCP server uses installed OpenClaw skills
# Skills already have their own API keys - no additional keys needed!
# - pair-scout, liquidity-guard, pair-age-check (DexScreener)
# - coin-deep, price-history, research-desk, exchange-intel (CoinGecko)
# - chain-tracker (CoinGecko)

# Wallet Authentication (optional but recommended for write operations)
# Public key for verification (0x address)
WALLET_ADDRESS=0x00BD00749EA0cBb28c6e9c4Ef0d95263aabCc0FD

# Server Config
PORT=3000
NODE_ENV=development

# Allowed origins (CORS) - comma separated
# For Railway: leave empty or set your Railway URL
ALLOWED_ORIGINS=http://localhost:3000,https://claude.ai

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
